@model Expense

@{
    ViewData["Title"] = "Delete Expense";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="fas fa-exclamation-triangle"></i> Delete Expense
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <h5 class="alert-heading">
                        <i class="fas fa-exclamation-circle"></i> Are you sure you want to delete this expense?
                    </h5>
                    <p class="mb-0">This action cannot be undone.</p>
                </div>

                <div class="card bg-light">
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Date</dt>
                            <dd class="col-sm-9">
                                <strong>@Model.Date.ToString("MMMM dd, yyyy")</strong>
                                <span class="badge bg-secondary ms-2">Week @Model.WeekNumber</span>
                            </dd>

                            <dt class="col-sm-3">Item Name</dt>
                            <dd class="col-sm-9">@Model.ItemName</dd>

                            <dt class="col-sm-3">Category</dt>
                            <dd class="col-sm-9">
                                <span class="badge" style="background-color: @Model.Category.ColorCode">
                                    @Model.Category.Name
                                </span>
                            </dd>

                            <dt class="col-sm-3">Amount</dt>
                            <dd class="col-sm-9">
                                <strong class="text-danger fs-5">@Model.Amount.ToString("C")</strong>
                            </dd>

                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <dt class="col-sm-3">Notes</dt>
                                <dd class="col-sm-9">@Model.Notes</dd>
                            }

                            <dt class="col-sm-3">Created</dt>
                            <dd class="col-sm-9">
                                <small class="text-muted">@Model.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")</small>
                            </dd>
                        </dl>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year" 
                           class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Yes, Delete This Expense
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year" 
               class="btn btn-link">
                <i class="fas fa-arrow-left"></i> Back to Expenses
            </a>
        </div>
    </div>
</div>
