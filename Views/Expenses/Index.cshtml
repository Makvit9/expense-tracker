@model IEnumerable<Expense>

@{
    ViewData["Title"] = "Expenses - " + ViewBag.MonthName;
}

<div class="row mb-3">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="fas fa-receipt"></i> Expenses - @ViewBag.MonthName
            </h1>
            <div>
                <div class="btn-group me-2">
                    <a asp-action="Index" asp-route-month="@(ViewBag.CurrentMonth == 1 ? 12 : ViewBag.CurrentMonth - 1)" 
                       asp-route-year="@(ViewBag.CurrentMonth == 1 ? ViewBag.CurrentYear - 1 : ViewBag.CurrentYear)" 
                       class="btn btn-outline-secondary">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                    <button type="button" class="btn btn-outline-secondary" disabled>@ViewBag.MonthName</button>
                    <a asp-action="Index" asp-route-month="@(ViewBag.CurrentMonth == 12 ? 1 : ViewBag.CurrentMonth + 1)" 
                       asp-route-year="@(ViewBag.CurrentMonth == 12 ? ViewBag.CurrentYear + 1 : ViewBag.CurrentYear)" 
                       class="btn btn-outline-secondary">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                    
                </div>
                <a asp-action="Create" asp-route-month="@ViewBag.CurrentMonth" asp-route-year="@ViewBag.CurrentYear" 
                   class="btn btn-primary">
                    <i class="fas fa-plus"></i> Add Expense
                </a>
                <a asp-action="ExportCsv" asp-route-month="@ViewBag.CurrentMonth" asp-route-year="@ViewBag.CurrentYear"
   class="btn btn-outline-success">
    <i class="fas fa-file-csv"></i> Export CSV
</a>
            </div>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Expenses</h6>
                    <h3 class="text-info">@Model.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Amount</h6>
                    <h3 class="text-danger">@Model.Sum(e => e.Amount).ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h6 class="text-muted">Average Expense</h6>
                    <h3 class="text-warning">@Model.Average(e => e.Amount).ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Expenses by Week (newest first) -->
    @for (int week = 5; week >= 1; week--)
    {
        var weekExpenses = Model.Where(e => e.WeekNumber == week).ToList();
        
        @if (weekExpenses.Any())
        {
            var collapseId = $"weekCollapse{week}";
            <div class="card mb-3">
                <div class="card-header bg-light" style="cursor: pointer;" 
                     data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="true" aria-controls="@collapseId">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-chevron-down me-2 collapse-icon" style="transition: transform 0.2s;"></i>
                            <span class="badge bg-secondary">Week @week</span>
                            <span class="text-muted ms-2">@weekExpenses.Count expense(s)</span>
                        </h5>
                        <strong class="text-danger">Total: @weekExpenses.Sum(e => e.Amount).ToString("C")</strong>
                    </div>
                </div>
                <div class="collapse show" id="@collapseId">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Item Name</th>
                                        <th>Category</th>
                                        <th class="text-end">Amount</th>
                                        <th>Notes</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var expense in weekExpenses.OrderByDescending(e => e.Date))
                                    {
                                        <tr>
                                            <td>
                                                <strong>@expense.Date.ToString("MMM dd")</strong>
                                                <br />
                                                <small class="text-muted">@expense.Date.ToString("ddd")</small>
                                            </td>
                                            <td>@expense.ItemName</td>
                                            <td>
                                                <span class="badge" style="background-color: @expense.Category.ColorCode">
                                                    @expense.Category.Name
                                                </span>
                                            </td>
                                            <td class="text-end">@expense.Amount.ToString("C")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(expense.Notes))
                                                {
                                                    <small class="text-muted">@expense.Notes</small>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-outline-warning" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-outline-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end"><strong>Week @week Subtotal:</strong></td>
                                        <td class="text-end"><strong>@weekExpenses.Sum(e => e.Amount).ToString("C")</strong></td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Monthly Total -->
    <div class="card border-primary">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Monthly Total</h4>
                <h3 class="text-primary mb-0">@Model.Sum(e => e.Amount).ToString("C")</h3>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-4"></i>
            <h4 class="text-muted">No expenses recorded for @ViewBag.MonthName</h4>
            <p class="text-muted">Start tracking your expenses to see them here.</p>
            <a asp-action="Create" asp-route-month="@ViewBag.CurrentMonth" asp-route-year="@ViewBag.CurrentYear" 
               class="btn btn-primary btn-lg mt-3">
                <i class="fas fa-plus"></i> Add Your First Expense
            </a>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Dashboard" asp-action="Index" asp-route-month="@ViewBag.CurrentMonth" asp-route-year="@ViewBag.CurrentYear" 
       class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

@section Scripts {
    <script>
        // Rotate chevron icon when collapsing/expanding
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function (header) {
            var target = document.querySelector(header.getAttribute('data-bs-target'));
            var icon = header.querySelector('.collapse-icon');

            target.addEventListener('hide.bs.collapse', function () {
                icon.style.transform = 'rotate(-90deg)';
            });
            target.addEventListener('show.bs.collapse', function () {
                icon.style.transform = 'rotate(0deg)';
            });
        });
    </script>
}