@model Expense

@{
    ViewData["Title"] = "Add Expense";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="fas fa-plus"></i> Add New Expense
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Date" class="form-label"></label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                            <small class="form-text text-muted">Week number will be calculated automatically</small>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                                <input asp-for="Amount" class="form-control" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ItemName" class="form-label"></label>
                        <input asp-for="ItemName" class="form-control" id="itemNameInput"
                               placeholder="e.g., Parliament cigarettes, Coffee, Groceries" list="frequentItems" />
                        <datalist id="frequentItems">
                            @foreach (var item in ViewBag.FrequentItems as List<string>)
                            {
                                <option value="@item"></option>
                            }
                        </datalist>
                        <span asp-validation-for="ItemName" class="text-danger"></span>
                        <small class="form-text text-muted">Start typing to see frequently purchased items</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"
                                  placeholder="Optional notes about this expense"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <!-- Hidden fields for month/year context -->
                    <input type="hidden" asp-for="Month" />
                    <input type="hidden" asp-for="Year" />
                    <input type="hidden" asp-for="WeekNumber" />

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        <strong>Quick Tip:</strong> Common items like "Parliament cigarettes" will appear
                        in the suggestions as you type, making future entries faster!
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year"
                               class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Save Expense
                        </button>
                        <button type="submit" name="addAnother" value="true" class="btn btn-success">
                            <i class="fas fa-plus"></i> Save & Add Another
                        </button>

                    </div>
                </form>
            </div>
        </div>

        <!-- Recent Expenses Helper -->
        @if (ViewBag.FrequentItems != null && (ViewBag.FrequentItems as List<string>).Any())
        {
            <div class="card mt-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="fas fa-history"></i> Your Frequent Purchases</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var item in ViewBag.FrequentItems as List<string>)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary quick-item" data-item="@item">
                                @item
                            </button>
                        }
                    </div>
                    <small class="text-muted d-block mt-2">Click to quickly fill the item name</small>
                </div>
            </div>
        }

        <div class="mt-3">
            <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year" class="btn btn-link">
                <i class="fas fa-arrow-left"></i> Back to Expenses
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
                $(document).ready(function () {
                    // Quick item selection
                    $('.quick-item').click(function () {
                        var itemName = $(this).data('item');
                        $('#itemNameInput').val(itemName);
                        $('#itemNameInput').focus();
                    });

                    // Auto-focus on amount after selecting date
                    $('#Date').change(function () {
                        $('#ItemName').focus();
                    });

                    // Currency formatting for amount input
                    $('#Amount').on('blur', function () {
                        var val = $(this).val();
                        if (val) {
                            $(this).val(parseFloat(val).toFixed(2));
                        }
                    });

                    // Set today's date as default if empty
                    var dateInput = $('#Date');
                    if (!dateInput.val()) {
                        var today = new Date().toISOString().split('T')[0];
                        dateInput.val(today);
                    }
                });


    </script>
}