@model IEnumerable<Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="row mb-3">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="fas fa-tags"></i> Categories
            </h1>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Category
            </a>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-12">
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            <strong>Tip:</strong> Categories help you organise and analyse your spending.
            Use the arrows to reorder them.
        </div>
    </div>
</div>

@if (Model.Any())
{
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i> Your Categories (@Model.Count())
                    </h5>
                </div>

                <!-- ══ DESKTOP TABLE ══ -->
                <div class="expense-table-wrap">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th width="80">Order</th>
                                        <th width="50">Color</th>
                                        <th>Name</th>
                                        <th>Description</th>
                                        <th width="100" class="text-center">Status</th>
                                        <th width="150" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var category in Model.OrderBy(c => c.DisplayOrder))
                                    {
                                        <tr class="@(!category.IsActive ? "table-secondary" : "")">
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <form asp-action="Reorder" asp-route-id="@category.Id"
                                                          asp-route-direction="up" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                                title="Move Up"
                                                                @(category.DisplayOrder == 1 ? "disabled" : "")>
                                                            <i class="fas fa-arrow-up"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="Reorder" asp-route-id="@category.Id"
                                                          asp-route-direction="down" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                                title="Move Down"
                                                                @(category.DisplayOrder == Model.Count() ? "disabled" : "")>
                                                            <i class="fas fa-arrow-down"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge"
                                                      style="background-color:@category.ColorCode;
                                                             width:40px;height:25px;display:inline-block;">
                                                    &nbsp;
                                                </span>
                                            </td>
                                            <td><strong>@category.Name</strong></td>
                                            <td><small class="text-muted">@category.Description</small></td>
                                            <td class="text-center">
                                                @if (category.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="Details" asp-route-id="@category.Id"
                                                       class="btn btn-outline-info" title="Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@category.Id"
                                                       class="btn btn-outline-warning" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@category.Id"
                                                       class="btn btn-outline-danger" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ══ MOBILE CARD LIST ══ -->
                <div class="expense-mobile-list">
                    @foreach (var category in Model.OrderBy(c => c.DisplayOrder))
                    {
                        <div class="cat-card @(!category.IsActive ? "cat-card--inactive" : "")">

                            <!-- Color swatch + name + status -->
                            <div class="cat-card__left">
                                <span class="cat-card__swatch"
                                      style="background-color:@category.ColorCode"></span>
                                <div class="cat-card__info">
                                    <span class="cat-card__name">@category.Name</span>
                                    @if (!string.IsNullOrEmpty(category.Description))
                                    {
                                        <span class="cat-card__desc">@category.Description</span>
                                    }
                                    <div class="mt-1">
                                        @if (category.IsActive)
                                        {
                                            <span class="badge bg-success" style="font-size:.65rem;">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary" style="font-size:.65rem;">Inactive</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Reorder + actions -->
                            <div class="cat-card__right">
                                <!-- Reorder arrows stacked vertically -->
                                <div class="cat-card__order">
                                    <form asp-action="Reorder" asp-route-id="@category.Id"
                                          asp-route-direction="up" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                @(category.DisplayOrder == 1 ? "disabled" : "")>
                                            <i class="fas fa-arrow-up"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Reorder" asp-route-id="@category.Id"
                                          asp-route-direction="down" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                                @(category.DisplayOrder == Model.Count() ? "disabled" : "")>
                                            <i class="fas fa-arrow-down"></i>
                                        </button>
                                    </form>
                                </div>

                                <!-- CRUD actions -->
                                <div class="cat-card__actions">
                                    <a asp-action="Edit" asp-route-id="@category.Id"
                                       class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@category.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </div>

                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

    <!-- Color Preview (desktop + mobile) -->
    <div class="row mt-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="fas fa-palette"></i> Category Colours</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var category in Model.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                        {
                            <span class="badge fs-6 px-3 py-2"
                                  style="background-color:@category.ColorCode">
                                @category.Name
                            </span>
                        }
                    </div>
                    <small class="text-muted d-block mt-2">
                        These colours appear in your charts and expense lists
                    </small>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-tags fa-4x text-muted mb-4"></i>
            <h4 class="text-muted">No categories yet</h4>
            <p class="text-muted">Start by creating your first category!</p>
            <a asp-action="Create" class="btn btn-primary btn-lg mt-3">
                <i class="fas fa-plus"></i> Create Your First Category
            </a>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
    </a>
</div>
