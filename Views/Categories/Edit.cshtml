@model Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="fas fa-edit"></i> Edit Category
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ColorCode" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="ColorCode" type="color" class="form-control form-control-color" 
                                       id="colorPicker" title="Choose a color" />
                                <input asp-for="ColorCode" type="text" class="form-control" 
                                       id="colorText" placeholder="#FF6B6B" maxlength="7" />
                            </div>
                            <span asp-validation-for="ColorCode" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" min="1" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                        <small class="form-text text-muted">
                            Inactive categories won't appear when adding new expenses
                        </small>
                    </div>

                    <!-- Color Preview -->
                    <div class="alert alert-light border" id="colorPreview">
                        <h6>Preview:</h6>
                        <span class="badge fs-5 px-3 py-2" id="previewBadge" style="background-color: @Model.ColorCode">
                            <span id="previewName">@Model.Name</span>
                        </span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save"></i> Update Category
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Suggested Colors -->
        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-palette"></i> Suggested Colors</h6>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#FF6B6B" style="background-color: #FF6B6B; color: white;">Red</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#4ECDC4" style="background-color: #4ECDC4; color: white;">Teal</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#45B7D1" style="background-color: #45B7D1; color: white;">Blue</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#96CEB4" style="background-color: #96CEB4; color: white;">Green</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#FFEAA7" style="background-color: #FFEAA7; color: black;">Yellow</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#DDA15E" style="background-color: #DDA15E; color: white;">Orange</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#BC6C25" style="background-color: #BC6C25; color: white;">Brown</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#E76F51" style="background-color: #E76F51; color: white;">Coral</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#2A9D8F" style="background-color: #2A9D8F; color: white;">Emerald</button>
                    <button type="button" class="btn btn-sm color-suggestion" data-color="#E9C46A" style="background-color: #E9C46A; color: black;">Gold</button>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-link">
                <i class="fas fa-arrow-left"></i> Back to Categories
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Sync color picker with text input
            $('#colorPicker').on('input', function() {
                var color = $(this).val();
                $('#colorText').val(color);
                $('#previewBadge').css('background-color', color);
            });

            $('#colorText').on('input', function() {
                var color = $(this).val();
                if (/^#[0-9A-F]{6}$/i.test(color)) {
                    $('#colorPicker').val(color);
                    $('#previewBadge').css('background-color', color);
                }
            });

            // Update preview name
            $('#Name').on('input', function() {
                var name = $(this).val() || 'Category Name';
                $('#previewName').text(name);
            });

            // Color suggestions
            $('.color-suggestion').click(function() {
                var color = $(this).data('color');
                $('#colorPicker').val(color);
                $('#colorText').val(color);
                $('#previewBadge').css('background-color', color);
            });
        });
    </script>
}
