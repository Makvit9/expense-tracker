@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="fas fa-exclamation-triangle"></i> Delete Category
                </h4>
            </div>
            <div class="card-body">
                @if (ViewBag.HasExpenses)
                {
                    <div class="alert alert-warning">
                        <h5 class="alert-heading">
                            <i class="fas fa-exclamation-circle"></i> This category has existing expenses!
                        </h5>
                        <p>
                            This category cannot be permanently deleted because it has expenses associated with it. 
                            Instead, it will be deactivated and hidden from new expense entries.
                        </p>
                        <hr />
                        <p class="mb-0">
                            <strong>What will happen:</strong> The category will be marked as inactive and won't appear 
                            when adding new expenses, but all existing expense records will remain intact.
                        </p>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <h5 class="alert-heading">
                            <i class="fas fa-exclamation-circle"></i> Are you sure you want to delete this category?
                        </h5>
                        <p class="mb-0">This action cannot be undone. This category has no expenses, so it will be permanently deleted.</p>
                    </div>
                }

                <div class="card bg-light">
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Name</dt>
                            <dd class="col-sm-9">
                                <span class="badge fs-5 px-3 py-2" style="background-color: @Model.ColorCode">
                                    @Model.Name
                                </span>
                            </dd>

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <dt class="col-sm-3">Description</dt>
                                <dd class="col-sm-9">@Model.Description</dd>
                            }

                            <dt class="col-sm-3">Display Order</dt>
                            <dd class="col-sm-9">@Model.DisplayOrder</dd>

                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Color Code</dt>
                            <dd class="col-sm-9">
                                @Model.ColorCode
                                <span class="badge ms-2" style="background-color: @Model.ColorCode; width: 50px; height: 25px; display: inline-block;">
                                    &nbsp;
                                </span>
                            </dd>
                        </dl>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        @if (ViewBag.HasExpenses)
                        {
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-eye-slash"></i> Deactivate Category
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Yes, Delete Permanently
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-link">
                <i class="fas fa-arrow-left"></i> Back to Categories
            </a>
        </div>
    </div>
</div>
