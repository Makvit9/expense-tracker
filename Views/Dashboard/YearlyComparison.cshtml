@model List<YearlyMonthData>

@{
    ViewData["Title"] = "Yearly Comparison - " + ViewBag.Year;
}

<div class="row mb-3">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="fas fa-calendar-alt"></i> @ViewBag.Year Overview
            </h1>
            <div class="btn-group">
                <a asp-action="YearlyComparison" asp-route-year="@(ViewBag.Year - 1)"
                   class="btn btn-outline-secondary">
                    <i class="fas fa-chevron-left"></i> @(ViewBag.Year - 1)
                </a>
                <button type="button" class="btn btn-outline-secondary" disabled>@ViewBag.Year</button>
                <a asp-action="YearlyComparison" asp-route-year="@(ViewBag.Year + 1)"
                   class="btn btn-outline-secondary">
                    @(ViewBag.Year + 1) <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Chart -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Monthly Comparison</h5>
            </div>
            <div class="card-body">
                <canvas id="yearlyChart" style="max-height:400px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Breakdown -->
@{
    decimal totalIncome   = Model.Sum(m => m.Income);
    decimal totalSpending = Model.Sum(m => m.TotalSpending);
    decimal totalBalance  = totalIncome - totalSpending;
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-table"></i> Monthly Details</h5>
            </div>

            <!-- ══ DESKTOP TABLE ══ -->
            <div class="expense-table-wrap">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th class="text-end">Income</th>
                                <th class="text-end">Spending</th>
                                <th class="text-end">Balance</th>
                                <th class="text-end">Savings Rate</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var month in Model)
                            {
                                var savingsRate = month.Income > 0
                                    ? ((month.Income - month.TotalSpending) / month.Income) * 100 : 0;
                                <tr>
                                    <td><strong>@month.Month</strong></td>
                                    <td class="text-end text-success">$@month.Income.ToString("F2")</td>
                                    <td class="text-end text-danger">$@month.TotalSpending.ToString("F2")</td>
                                    <td class="text-end @(month.Balance >= 0 ? "text-info" : "text-warning")">
                                        $@month.Balance.ToString("F2")
                                    </td>
                                    <td class="text-end">
                                        @if (month.Income > 0)
                                        {
                                            <span class="badge @(savingsRate >= 20 ? "bg-success" : savingsRate >= 10 ? "bg-info" : "bg-warning")">
                                                @savingsRate.ToString("N1")%
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Expenses" asp-action="Index"
                                           asp-route-month="@month.MonthNumber"
                                           asp-route-year="@ViewBag.Year"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th>Total</th>
                                <th class="text-end text-success">$@totalIncome.ToString("F2")</th>
                                <th class="text-end text-danger">$@totalSpending.ToString("F2")</th>
                                <th class="text-end @(totalBalance >= 0 ? "text-info" : "text-warning")">
                                    $@totalBalance.ToString("F2")
                                </th>
                                <th class="text-end">
                                    @if (totalIncome > 0)
                                    {
                                        var yr = ((totalIncome - totalSpending) / totalIncome) * 100;
                                        <span class="badge @(yr >= 20 ? "bg-success" : yr >= 10 ? "bg-info" : "bg-warning")">
                                            @yr.ToString("N1")%
                                        </span>
                                    }
                                </th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- ══ MOBILE CARD LIST ══ -->
            <div class="expense-mobile-list">
                @foreach (var month in Model)
                {
                    var savingsRate = month.Income > 0
                        ? ((month.Income - month.TotalSpending) / month.Income) * 100 : 0;

                    <div class="yearly-row">
                        <!-- Month name + savings badge -->
                        <div class="yearly-row__header">
                            <span class="yearly-row__month">@month.Month</span>
                            @if (month.Income > 0)
                            {
                                <span class="badge @(savingsRate >= 20 ? "bg-success" : savingsRate >= 10 ? "bg-info" : "bg-warning")">
                                    @savingsRate.ToString("N1")%
                                </span>
                            }
                            <a asp-controller="Expenses" asp-action="Index"
                               asp-route-month="@month.MonthNumber"
                               asp-route-year="@ViewBag.Year"
                               class="btn btn-sm btn-outline-primary ms-auto">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                        <!-- Three figures -->
                        <div class="yearly-row__figures">
                            <div class="yearly-row__fig">
                                <span class="yearly-row__label">Income</span>
                                <span class="yearly-row__val text-success">$@month.Income.ToString("F2")</span>
                            </div>
                            <div class="yearly-row__fig">
                                <span class="yearly-row__label">Spent</span>
                                <span class="yearly-row__val text-danger">$@month.TotalSpending.ToString("F2")</span>
                            </div>
                            <div class="yearly-row__fig">
                                <span class="yearly-row__label">Balance</span>
                                <span class="yearly-row__val @(month.Balance >= 0 ? "text-info" : "text-warning")">
                                    $@month.Balance.ToString("F2")
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Mobile year totals -->
                <div class="yearly-row yearly-row--total">
                    <div class="yearly-row__header">
                        <span class="yearly-row__month">Year Total</span>
                        @if (totalIncome > 0)
                        {
                            var yr = ((totalIncome - totalSpending) / totalIncome) * 100;
                            <span class="badge @(yr >= 20 ? "bg-success" : yr >= 10 ? "bg-info" : "bg-warning")">
                                @yr.ToString("N1")%
                            </span>
                        }
                    </div>
                    <div class="yearly-row__figures">
                        <div class="yearly-row__fig">
                            <span class="yearly-row__label">Income</span>
                            <span class="yearly-row__val text-success">$@totalIncome.ToString("F2")</span>
                        </div>
                        <div class="yearly-row__fig">
                            <span class="yearly-row__label">Spent</span>
                            <span class="yearly-row__val text-danger">$@totalSpending.ToString("F2")</span>
                        </div>
                        <div class="yearly-row__fig">
                            <span class="yearly-row__label">Balance</span>
                            <span class="yearly-row__val @(totalBalance >= 0 ? "text-info" : "text-warning")">
                                $@totalBalance.ToString("F2")
                            </span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('yearlyChart').getContext('2d');
        const yearlyData = @Html.Raw(Json.Serialize(Model));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: yearlyData.map(d => d.month),
                datasets: [
                    {
                        label: 'Income',
                        data: yearlyData.map(d => d.income),
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Spending',
                        data: yearlyData.map(d => d.totalSpending),
                        borderColor: '#ef4444',
                        backgroundColor: 'rgba(239,68,68,.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Balance',
                        data: yearlyData.map(d => d.balance),
                        borderColor: '#06b6d4',
                        backgroundColor: 'rgba(6,182,212,.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: v => '$' + v.toFixed(0) }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.dataset.label + ': $' + ctx.parsed.y.toFixed(2)
                        }
                    }
                }
            }
        });
    </script>
}
