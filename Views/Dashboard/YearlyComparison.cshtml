@model List<YearlyMonthData>

@{
    ViewData["Title"] = "Yearly Comparison - " + ViewBag.Year;
}

<div class="row mb-3">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="fas fa-calendar-alt"></i> @ViewBag.Year Overview
            </h1>
            <div class="btn-group">
                <a asp-action="YearlyComparison" asp-route-year="@(ViewBag.Year - 1)" class="btn btn-outline-secondary">
                    <i class="fas fa-chevron-left"></i> @(ViewBag.Year - 1)
                </a>
                <button type="button" class="btn btn-outline-secondary" disabled>@ViewBag.Year</button>
                <a asp-action="YearlyComparison" asp-route-year="@(ViewBag.Year + 1)" class="btn btn-outline-secondary">
                    @(ViewBag.Year + 1) <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Yearly Summary -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Monthly Comparison</h5>
            </div>
            <div class="card-body">
                <canvas id="yearlyChart" style="max-height: 400px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Breakdown Table -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-table"></i> Monthly Details</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th class="text-end">Income</th>
                                <th class="text-end">Spending</th>
                                <th class="text-end">Balance</th>
                                <th class="text-end">Savings Rate</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal totalIncome = 0;
                                decimal totalSpending = 0;
                            }
                            @foreach (var month in Model)
                            {
                                totalIncome += month.Income;
                                totalSpending += month.TotalSpending;
                                var savingsRate = month.Income > 0
                                    ? ((month.Income - month.TotalSpending) / month.Income) * 100
                                    : 0;

                                <tr>
                                    <td><strong>@month.Month</strong></td>
                                    <td class="text-end text-success">$@month.Income.ToString("F2")</td>
                                    <td class="text-end text-danger">$@month.TotalSpending.ToString("F2")</td>
                                    <td class="text-end @(month.Balance >= 0 ? "text-info" : "text-warning")">
                                           $@month.Balance.ToString("F2")
                                    </td>
                                    <td class="text-end">
                                        @if (month.Income > 0)
                                        {
                                            <span class="badge @(savingsRate >= 20 ? "bg-success" : savingsRate >= 10 ? "bg-info" : "bg-warning")">
                                                @savingsRate.ToString("N1")%
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Expenses" asp-action="Index" asp-route-month="@month.MonthNumber" asp-route-year="@ViewBag.Year"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th>Total</th>
                                <th class="text-end text-success">$@totalIncome.ToString("F2")</th>
                                <th class="text-end text-danger">$@totalSpending.ToString("F2")</th>
                                <th class="text-end @(totalIncome - totalSpending >= 0 ? "text-info" : "text-warning")">
                                    $@((totalIncome - totalSpending).ToString("F2"))
                                </th>
                                <th class="text-end">
                                    @if (totalIncome > 0)
                                    {
                                        var yearSavings = ((totalIncome - totalSpending) / totalIncome) * 100;
                                        <span class="badge @(yearSavings >= 20 ? "bg-success" : yearSavings >= 10 ? "bg-info" : "bg-warning")">
                                            @yearSavings.ToString("N1")%
                                        </span>
                                    }
                                </th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('yearlyChart').getContext('2d');
        const yearlyData = @Html.Raw(Json.Serialize(Model));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: yearlyData.map(d => d.month),
                datasets: [
                    {
                        label: 'Income',
                        data: yearlyData.map(d => d.income),
                        borderColor: '#28a745',
                        backgroundColor: 'rgba(40, 167, 69, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Spending',
                        data: yearlyData.map(d => d.totalSpending),
                        borderColor: '#dc3545',
                        backgroundColor: 'rgba(220, 53, 69, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Balance',
                        data: yearlyData.map(d => d.balance),
                        borderColor: '#17a2b8',
                        backgroundColor: 'rgba(23, 162, 184, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '$' + value.toFixed(0);
                            }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                label += '$' + context.parsed.y.toFixed(2);
                                return label;
                            }
                        }
                    }
                }
            }
        });
    </script>
}